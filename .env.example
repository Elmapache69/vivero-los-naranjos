# ══════════════════════════════════════════════════════
#  Jardín y Vivero Los Naranjos — Variables de Entorno
#  Copia este archivo como .env y completa los valores
# ══════════════════════════════════════════════════════

# ── Base de datos ──────────────────────────────────────
# Para desarrollo local con Docker:
DATABASE_URL=postgresql://vivero_user:vivero_pass@db:5432/vivero_db

# Para Railway (se asigna automáticamente):
# DATABASE_URL=postgresql://...

# ── Seguridad ──────────────────────────────────────────
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_segura_de_64_caracteres_minimo

# Duración del token de acceso (minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Duración del token de refresco (días)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 2FA (TOTP) ─────────────────────────────────────────
TOTP_ISSUER=Vivero Los Naranjos

# ── Aplicación ─────────────────────────────────────────
APP_NAME=Jardín y Vivero Los Naranjos
APP_ENV=development
# En producción cambiar a: production
DEBUG=true

# ── CORS ───────────────────────────────────────────────
# URLs permitidas separadas por coma
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=10

# ── Backups ────────────────────────────────────────────
# Opcional: configurar S3 o similar para backups automáticos
# BACKUP_S3_BUCKET=
# BACKUP_S3_KEY=
# BACKUP_S3_SECRET=
# BACKUP_SCHEDULE_HOURS=24
